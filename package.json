{
  "name": "sqlxs",
  "displayName": "SQLxs",
  "description": "Database tools for VS Code — IntelliJ/DataGrip-style data grid, SQL console with CodeLens, inline editing, transpose view. MySQL, PostgreSQL, TimescaleDB (xs = extra SQL).",
  "version": "1.3.0",
  "publisher": "abridge",
  "author": "abridge",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexbridge/abridge-vsx-sqlxs.git"
  },
  "homepage": "https://github.com/alexbridge/abridge-vsx-sqlxs",
  "bugs": {
    "url": "https://github.com/alexbridge/abridge-vsx-sqlxs/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icons/logo.png",
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "database",
    "sql",
    "mysql",
    "postgres",
    "postgresql",
    "timescaledb",
    "datagrip",
    "intellij",
    "jetbrains",
    "phpstorm",
    "webstorm",
    "db-client",
    "sql-client",
    "database-tools",
    "data-grid",
    "sql-console",
    "db-viewer",
    "dbcode",
    "sqltools"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "build": "node esbuild.js",
    "build:webview": "node esbuild-webview.js",
    "build:css": "npx @tailwindcss/cli -i webview/styles.css -o dist/tailwind.css --minify",
    "build:all": "npm run build && npm run build:webview && npm run build:css",
    "build:production": "rm -rf dist && node esbuild.js --production && node esbuild-webview.js --production && npm run build:css",
    "package": "yes | npx @vscode/vsce package --no-dependencies",
    "watch": "node esbuild.js --watch",
    "lint": "npm run format:check && tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"webview/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"webview/**/*.{ts,tsx}\""
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sqlxs",
          "title": "SQLxs",
          "icon": "icons/sidebar.svg"
        }
      ]
    },
    "views": {
      "sqlxs": [
        {
          "id": "sqlxs.explorer",
          "name": "Connections",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "sqlxs.addConnection",
        "title": "Add Connection",
        "category": "SQLxs",
        "icon": "$(plus)"
      },
      {
        "command": "sqlxs.refreshConnections",
        "title": "Refresh Connections",
        "category": "SQLxs",
        "icon": "$(refresh)"
      },
      {
        "command": "sqlxs.openSqlConsole",
        "title": "New Query",
        "category": "SQLxs"
      },
      {
        "command": "sqlxs.openTableData",
        "title": "Open Table Data",
        "category": "SQLxs"
      },
      {
        "command": "sqlxs.showSchema",
        "title": "Show Table Schema",
        "category": "SQLxs"
      },
      {
        "command": "sqlxs.toggleTranspose",
        "title": "Toggle Transpose View",
        "category": "SQLxs",
        "icon": "$(layout-centered)"
      },
      {
        "command": "sqlxs.exportResults",
        "title": "Export Results",
        "category": "SQLxs",
        "icon": "$(export)"
      },
      {
        "command": "sqlxs.importConnectionClipboard",
        "title": "Import Connection from Clipboard",
        "category": "SQLxs"
      },
      {
        "command": "sqlxs.importFromJson",
        "title": "Import Connection from JSON",
        "category": "SQLxs",
        "icon": "$(json)"
      },
      {
        "command": "sqlxs.importFromIntelliJ",
        "title": "Import from IntelliJ XML",
        "category": "SQLxs",
        "icon": "$(file-code)"
      },
      {
        "command": "sqlxs.editConnection",
        "title": "Edit Connection",
        "category": "SQLxs",
        "icon": "$(edit)"
      },
      {
        "command": "sqlxs.deleteConnection",
        "title": "Delete Connection",
        "category": "SQLxs",
        "icon": "$(trash)"
      },
      {
        "command": "sqlxs.openSqlConsole",
        "title": "Open SQL Console",
        "category": "SQLxs",
        "icon": "$(terminal)"
      },
      {
        "command": "sqlxs.runSqlBlock",
        "title": "Run SQL Block",
        "category": "SQLxs"
      },
      {
        "command": "sqlxs.runCurrentBlock",
        "title": "Run Current SQL Block",
        "category": "SQLxs"
      },
      {
        "command": "sqlxs.openSqlFile",
        "title": "Open SQL File",
        "category": "SQLxs"
      },
      {
        "command": "sqlxs.renameSqlConsole",
        "title": "Rename",
        "category": "SQLxs"
      },
      {
        "command": "sqlxs.deleteSqlConsole",
        "title": "Delete",
        "category": "SQLxs",
        "icon": "$(trash)"
      },
      {
        "command": "sqlxs.exportConnectionJson",
        "title": "Export Connection as JSON",
        "category": "SQLxs",
        "icon": "$(json)"
      },
      {
        "command": "sqlxs.exportConnectionXml",
        "title": "Export Connection as IntelliJ XML",
        "category": "SQLxs",
        "icon": "$(file-code)"
      },
      {
        "command": "sqlxs.formatSqlBlock",
        "title": "Format SQL Block",
        "category": "SQLxs"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sqlxs.addConnection",
          "when": "view == sqlxs.explorer",
          "group": "navigation"
        },
        {
          "command": "sqlxs.importFromJson",
          "when": "view == sqlxs.explorer",
          "group": "navigation@1"
        },
        {
          "command": "sqlxs.importFromIntelliJ",
          "when": "view == sqlxs.explorer",
          "group": "navigation@2"
        },
        {
          "command": "sqlxs.refreshConnections",
          "when": "view == sqlxs.explorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "sqlxs.openSqlConsole",
          "when": "view == sqlxs.explorer && viewItem == connectionNode",
          "group": "inline@0"
        },
        {
          "command": "sqlxs.exportConnectionJson",
          "when": "view == sqlxs.explorer && viewItem == connectionNode",
          "group": "inline@1"
        },
        {
          "command": "sqlxs.exportConnectionXml",
          "when": "view == sqlxs.explorer && viewItem == connectionNode",
          "group": "inline@2"
        },
        {
          "command": "sqlxs.editConnection",
          "when": "view == sqlxs.explorer && viewItem == connectionNode",
          "group": "inline@3"
        },
        {
          "command": "sqlxs.deleteConnection",
          "when": "view == sqlxs.explorer && viewItem == connectionNode",
          "group": "inline@4"
        },
        {
          "command": "sqlxs.openSqlConsole",
          "when": "view == sqlxs.explorer && viewItem == sqlConsolesNode",
          "group": "inline@1"
        },
        {
          "command": "sqlxs.renameSqlConsole",
          "when": "view == sqlxs.explorer && viewItem == sqlConsoleFileNode",
          "group": "1_edit@1"
        },
        {
          "command": "sqlxs.deleteSqlConsole",
          "when": "view == sqlxs.explorer && viewItem == sqlConsoleFileNode",
          "group": "1_edit@2"
        },
        {
          "command": "sqlxs.exportConnectionJson",
          "when": "view == sqlxs.explorer && viewItem == connectionNode",
          "group": "3_export@1"
        },
        {
          "command": "sqlxs.exportConnectionXml",
          "when": "view == sqlxs.explorer && viewItem == connectionNode",
          "group": "3_export@2"
        },
        {
          "command": "sqlxs.openTableData",
          "when": "view == sqlxs.explorer && (viewItem == tableNode || viewItem == viewNode)",
          "group": "1_query"
        },
        {
          "command": "sqlxs.showSchema",
          "when": "view == sqlxs.explorer && viewItem == tableNode",
          "group": "2_schema"
        }
      ]
    },
    "keybindings": [
      {
        "command": "sqlxs.toggleTranspose",
        "key": "ctrl+t",
        "mac": "cmd+t",
        "when": "webviewId == sqlxs.resultGrid"
      },
      {
        "command": "sqlxs.runCurrentBlock",
        "key": "f5",
        "mac": "f5",
        "when": "editorTextFocus && resourceExtname == .sql"
      }
    ],
    "configurationDefaults": {
      "[sql]": {
        "editor.defaultFormatter": "abridge.sqlxs"
      }
    },
    "configuration": {
      "title": "SQLxs",
      "properties": {
        "sqlxs.defaultPageSize": {
          "type": "number",
          "default": 50,
          "description": "Rows per page in the result grid."
        },
        "sqlxs.defaultView": {
          "type": "string",
          "enum": [
            "horizontal",
            "vertical"
          ],
          "default": "horizontal",
          "description": "Default view layout for query results."
        },
        "sqlxs.nullDisplay": {
          "type": "string",
          "default": "NULL",
          "description": "String to display for NULL values."
        },
        "sqlxs.maxColumnWidth": {
          "type": "number",
          "default": 300,
          "description": "Maximum width of a column in the result grid (pixels)."
        },
        "sqlxs.confirmOnDelete": {
          "type": "boolean",
          "default": true,
          "description": "Confirm before deleting a connection."
        }
      }
    }
  },
  "dependencies": {
    "mysql2": "^3.9.2",
    "pg": "^8.11.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sql-formatter": "^15.7.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.0"
  }
}
